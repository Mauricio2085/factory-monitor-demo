# Server
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/factory_monitor
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=factory_monitor

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# CORS
CORS_ORIGIN=http://localhost:5173

# Socket.io
SOCKET_PORT=3000

# Telemetry ingestion (Timescale machine_telemetry)
# MQTT: leave MQTT_URL empty to disable subscriber
MQTT_URL=
MQTT_TOPIC_PREFIX=factory
# HTTP POST /api/internal/telemetry — leave empty to disable route (returns 503)
INGESTION_TOKEN=